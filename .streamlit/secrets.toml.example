[seoul_api]
# 서울 열린데이터광장(data.seoul.go.kr)에서 발급받은 인증키를 채워넣고
# 이 파일을 secrets.toml 로 복사해서 사용하세요 (secrets.toml은 .gitignore로 제외됨).
# 인증키 발급: https://data.seoul.go.kr/together/mypage/actkeyMain.do
subway_congestion_key = "여기에_지하철혼잡도_인증키"
subway_ridership_key = "여기에_지하철_승하차_인증키"
bus_ridership_key = "여기에_버스_승하차_인증키"
